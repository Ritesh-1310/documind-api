# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/documind"

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=documind-uploads
S3_ENDPOINT=http://localhost:9000   # remove this for real AWS S3

# AI
GROQ_API_KEY=your_groq_api_key     # free at console.groq.com
OPENAI_API_KEY=your_openai_api_key # optional, for embeddings

# Ollama (local embeddings - free)
# Run: ollama pull nomic-embed-text
